model StandupLogs{
    id          String   @id @default(uuid())
    workspaceId String?
    workSpace   Workspace? @relation(fields: [workspaceId], references: [id])

    userId      String 
    user       User @relation(fields: [userId], references: [id])

    todayWork  String
    tomorrowWork  String
    blocker     String?
    blockerUrl  String[]
    projectTags  String[]

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("standup_logs")
  
}