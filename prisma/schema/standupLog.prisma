model StandupLog{
    id          String   @id @default(uuid())
    workspaceId String?
    userId      String
    role        TEAM_ROLE   @default(MEMBER)
    todayWork  String
    tomorrowWork  String
    blocker     String?
    blockerUrl  String?
    projectTag  String?

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}