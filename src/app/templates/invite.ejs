<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          sans-serif;
        background-color: #f4f4f5;
        padding: 40px 20px;
      }

      .container {
        max-width: 560px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }

      .header {
        background-color: #18181b;
        padding: 32px;
        text-align: center;
      }

      .logo {
        font-size: 24px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
      }

      .logo span {
        color: #6366f1;
      }

      .body {
        padding: 40px 32px;
      }

      .tag {
        display: inline-block;
        background-color: #ede9fe;
        color: #6366f1;
        font-size: 12px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 999px;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      h1 {
        font-size: 22px;
        font-weight: 700;
        color: #18181b;
        margin-bottom: 12px;
        line-height: 1.3;
      }

      p {
        font-size: 15px;
        color: #52525b;
        line-height: 1.6;
        margin-bottom: 16px;
      }

      .workspace-card {
        background-color: #fafafa;
        border: 1px solid #e4e4e7;
        border-radius: 8px;
        padding: 16px 20px;
        margin: 24px 0;
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .workspace-icon {
        width: 40px;
        height: 40px;
        background-color: #6366f1;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
      }

      .workspace-name {
        font-size: 16px;
        font-weight: 600;
        color: #18181b;
      }

      .workspace-meta {
        font-size: 13px;
        color: #71717a;
        margin-top: 2px;
      }

      .btn {
        display: block;
        background-color: #6366f1;
        color: #ffffff !important;
        text-decoration: none;
        text-align: center;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        margin: 28px 0;
      }

      .divider {
        border: none;
        border-top: 1px solid #e4e4e7;
        margin: 24px 0;
      }

      .expire-notice {
        font-size: 13px;
        color: #a1a1aa;
        text-align: center;
      }

      .fallback-link {
        font-size: 13px;
        color: #a1a1aa;
        margin-top: 16px;
      }

      .fallback-link a {
        color: #6366f1;
        word-break: break-all;
      }

      .footer {
        background-color: #fafafa;
        border-top: 1px solid #e4e4e7;
        padding: 24px 32px;
        text-align: center;
      }

      .footer p {
        font-size: 13px;
        color: #a1a1aa;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div class="container">

      <!-- Header -->
      <div class="header">
        <div class="logo">Dev<span>Log</span></div>
      </div>

      <!-- Body -->
      <div class="body">
        <div class="tag">Team Invitation</div>

        <h1>You've been invited to join a workspace</h1>

        <p>Hi <%= inviteeEmail %>,</p>

        <p>
          <strong><%= adminName %></strong> has invited you to join their
          workspace on DevLog — where dev teams track daily standups,
          streaks, and blockers.
        </p>

        <!-- Workspace Card -->
        <div class="workspace-card">
          <div class="workspace-icon">🏢</div>
          <div>
            <div class="workspace-name"><%= workspaceName %></div>
            <div class="workspace-meta">Invited by <%= adminName %></div>
          </div>
        </div>

        <p>Click the button below to accept your invitation and get started:</p>

        <!-- CTA Button -->
        <a href="<%= inviteUrl %>" class="btn">
          Accept Invitation →
        </a>

        <hr class="divider" />

        <p class="expire-notice">
          ⏳ This invitation expires in <strong>7 days</strong>
        </p>

        <p class="fallback-link">
          Button not working? Copy and paste this link into your browser:<br />
          <a href="<%= inviteUrl %>"><%= inviteUrl %></a>
        </p>
      </div>

      <!-- Footer -->
      <div class="footer">
        <p>
          You received this email because someone invited you to DevLog.<br />
          If you didn't expect this, you can safely ignore it.
        </p>
      </div>

    </div>
  </body>
</html>