<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          sans-serif;
        background-color: #f4f4f5;
        padding: 40px 20px;
      }

      .container {
        max-width: 560px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }

      .header {
        background-color: #18181b;
        padding: 32px;
        text-align: center;
      }

      .logo {
        font-size: 24px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
      }

      .logo span {
        color: #6366f1;
      }

      .success-banner {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        padding: 40px 32px;
        text-align: center;
      }

      .success-icon {
        font-size: 48px;
        margin-bottom: 16px;
      }

      .success-title {
        font-size: 24px;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 8px;
      }

      .success-sub {
        font-size: 15px;
        color: #c4b5fd;
      }

      .body {
        padding: 40px 32px;
      }

      p {
        font-size: 15px;
        color: #52525b;
        line-height: 1.6;
        margin-bottom: 16px;
      }

      /* Receipt Card */
      .receipt-card {
        background-color: #fafafa;
        border: 1px solid #e4e4e7;
        border-radius: 8px;
        padding: 20px;
        margin: 24px 0;
      }

      .receipt-title {
        font-size: 13px;
        font-weight: 700;
        color: #71717a;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
      }

      .receipt-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f4f4f5;
        font-size: 14px;
      }

      .receipt-row:last-child {
        border-bottom: none;
        padding-top: 12px;
        margin-top: 4px;
        font-weight: 700;
        font-size: 15px;
        color: #18181b;
      }

      .receipt-label {
        color: #71717a;
      }

      .receipt-value {
        color: #18181b;
        font-weight: 500;
      }

      /* Features */
      .features-card {
        background-color: #fafafa;
        border: 1px solid #e4e4e7;
        border-radius: 8px;
        padding: 20px;
        margin: 24px 0;
      }

      .features-title {
        font-size: 13px;
        font-weight: 700;
        color: #71717a;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
      }

      .feature-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
        font-size: 14px;
        color: #3f3f46;
      }

      .feature-icon {
        color: #6366f1;
        font-size: 16px;
        flex-shrink: 0;
      }

      .btn {
        display: block;
        background-color: #6366f1;
        color: #ffffff !important;
        text-decoration: none;
        text-align: center;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        margin: 28px 0;
      }

      .divider {
        border: none;
        border-top: 1px solid #e4e4e7;
        margin: 24px 0;
      }

      .footer {
        background-color: #fafafa;
        border-top: 1px solid #e4e4e7;
        padding: 24px 32px;
        text-align: center;
      }

      .footer p {
        font-size: 13px;
        color: #a1a1aa;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div class="container">

      <!-- Header -->
      <div class="header">
        <div class="logo">Dev<span>Log</span></div>
      </div>

      <!-- Success Banner -->
      <div class="success-banner">
        <div class="success-icon">🎉</div>
        <div class="success-title">Welcome to DevLog Pro!</div>
        <div class="success-sub">Your upgrade was successful</div>
      </div>

      <!-- Body -->
      <div class="body">

        <p>Hi <strong><%= name %></strong>,</p>

        <p>
          Your payment was successful and your account has been upgraded
          to <strong>DevLog Pro</strong>. All Pro features are now
          unlocked and ready to use.
        </p>

        <!-- Receipt -->
        <div class="receipt-card">
          <div class="receipt-title">🧾 Payment Receipt</div>
          <div class="receipt-row">
            <span class="receipt-label">Plan</span>
            <span class="receipt-value">DevLog Pro</span>
          </div>
          <div class="receipt-row">
            <span class="receipt-label">Transaction ID</span>
            <span class="receipt-value"><%= transactionId %></span>
          </div>
          <div class="receipt-row">
            <span class="receipt-label">Date</span>
            <span class="receipt-value"><%= date %></span>
          </div>
          <div class="receipt-row">
            <span class="receipt-label">Total Paid</span>
            <span class="receipt-value">$<%= amount %></span>
          </div>
        </div>

        <!-- Pro Features -->
        <div class="features-card">
          <div class="features-title">✨ What's Unlocked</div>
          <div class="feature-item">
            <span class="feature-icon">✅</span>
            Create unlimited workspaces
          </div>
          <div class="feature-item">
            <span class="feature-icon">✅</span>
            Invite team members
          </div>
          <div class="feature-item">
            <span class="feature-icon">✅</span>
            Team standup feed
          </div>
          <div class="feature-item">
            <span class="feature-icon">✅</span>
            Blocker alerts
          </div>
          <div class="feature-item">
            <span class="feature-icon">✅</span>
            Weekly team reports
          </div>
          <div class="feature-item">
            <span class="feature-icon">✅</span>
            Unlimited log history
          </div>
        </div>

        <p>Ready to get started? Head to your dashboard and create your first workspace:</p>

        <a href="<%= dashboardUrl %>" class="btn">
          Go to Dashboard →
        </a>

        <hr class="divider" />

        <p style="font-size: 13px; color: #a1a1aa; text-align: center;">
          Questions? Reply to this email and we'll be happy to help.
        </p>

      </div>

      <!-- Footer -->
      <div class="footer">
        <p>
          © 2026 DevLog. All rights reserved.<br />
          This is an automated receipt, please do not reply.
        </p>
      </div>

    </div>
  </body>
</html>