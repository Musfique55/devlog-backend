<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          sans-serif;
        background-color: #f4f4f5;
        padding: 40px 20px;
      }

      .container {
        max-width: 560px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }

      .header {
        background-color: #18181b;
        padding: 32px;
        text-align: center;
      }

      .logo {
        font-size: 24px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
      }

      .logo span {
        color: #6366f1;
      }

      .warning-banner {
        background: linear-gradient(135deg, #d97706, #b45309);
        padding: 40px 32px;
        text-align: center;
      }

      .warning-icon {
        font-size: 48px;
        margin-bottom: 16px;
      }

      .warning-title {
        font-size: 24px;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 8px;
      }

      .warning-sub {
        font-size: 15px;
        color: #fde68a;
      }

      .body {
        padding: 40px 32px;
      }

      p {
        font-size: 15px;
        color: #52525b;
        line-height: 1.6;
        margin-bottom: 16px;
      }

      .lost-features {
        background-color: #fafafa;
        border: 1px solid #e4e4e7;
        border-radius: 8px;
        padding: 20px;
        margin: 24px 0;
      }

      .lost-title {
        font-size: 13px;
        font-weight: 700;
        color: #71717a;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
      }

      .feature-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
        font-size: 14px;
        color: #71717a;
        text-decoration: line-through;
      }

      .feature-icon {
        font-size: 14px;
        flex-shrink: 0;
      }

      .still-have {
        background-color: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        padding: 20px;
        margin: 24px 0;
      }

      .still-title {
        font-size: 13px;
        font-weight: 700;
        color: #16a34a;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
      }

      .still-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
        font-size: 14px;
        color: #3f3f46;
      }

      .btn {
        display: block;
        background-color: #6366f1;
        color: #ffffff !important;
        text-decoration: none;
        text-align: center;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        margin: 28px 0;
      }

      .divider {
        border: none;
        border-top: 1px solid #e4e4e7;
        margin: 24px 0;
      }

      .footer {
        background-color: #fafafa;
        border-top: 1px solid #e4e4e7;
        padding: 24px 32px;
        text-align: center;
      }

      .footer p {
        font-size: 13px;
        color: #a1a1aa;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div class="container">

      <!-- Header -->
      <div class="header">
        <div class="logo">Dev<span>Log</span></div>
      </div>

      <!-- Warning Banner -->
      <div class="warning-banner">
        <div class="warning-icon">⏰</div>
        <div class="warning-title">Your Pro Plan Has Expired</div>
        <div class="warning-sub">Your account has been downgraded to Free</div>
      </div>

      <!-- Body -->
      <div class="body">

        <p>Hi <strong><%= name %></strong>,</p>

        <p>
          Your DevLog Pro subscription has expired and your account has
          been downgraded to the Free plan. You won't lose any of your
          existing data, but some features are no longer available.
        </p>

        <!-- Lost Features -->
        <div class="lost-features">
          <div class="lost-title">❌ No Longer Available</div>
          <div class="feature-item">
            <span class="feature-icon">✕</span>
            Create workspaces
          </div>
          <div class="feature-item">
            <span class="feature-icon">✕</span>
            Invite team members
          </div>
          <div class="feature-item">
            <span class="feature-icon">✕</span>
            Blocker alerts
          </div>
          <div class="feature-item">
            <span class="feature-icon">✕</span>
            Weekly team reports
          </div>
          <div class="feature-item">
            <span class="feature-icon">✕</span>
            Unlimited log history
          </div>
        </div>

        <!-- Still Have -->
        <div class="still-have">
          <div class="still-title">✅ Still Available</div>
          <div class="still-item">
            <span>✅</span>
            Solo standup logging
          </div>
          <div class="still-item">
            <span>✅</span>
            Streak tracking
          </div>
          <div class="still-item">
            <span>✅</span>
            Last 30 days history
          </div>
          <div class="still-item">
            <span>✅</span>
            Join existing workspaces
          </div>
        </div>

        <p>
          Renew your Pro plan to restore full access and keep your
          team collaboration going:
        </p>

        <a href="<%= upgradeUrl %>" class="btn">
          Renew Pro Plan — $20 →
        </a>

        <hr class="divider" />

        <p style="font-size: 13px; color: #a1a1aa; text-align: center;">
          Questions about your subscription? Reply to this email
          and we'll be happy to help.
        </p>

      </div>

      <!-- Footer -->
      <div class="footer">
        <p>
          © 2026 DevLog. All rights reserved.<br />
          This is an automated email, please do not reply.
        </p>
      </div>

    </div>
  </body>
</html>