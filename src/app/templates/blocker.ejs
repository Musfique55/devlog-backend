<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          sans-serif;
        background-color: #f4f4f5;
        padding: 40px 20px;
      }

      .container {
        max-width: 560px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }

      .header {
        background-color: #18181b;
        padding: 32px;
        text-align: center;
      }

      .logo {
        font-size: 24px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
      }

      .logo span {
        color: #6366f1;
      }

      .body {
        padding: 40px 32px;
      }

      .tag {
        display: inline-block;
        background-color: #fee2e2;
        color: #dc2626;
        font-size: 12px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 999px;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      h1 {
        font-size: 22px;
        font-weight: 700;
        color: #18181b;
        margin-bottom: 12px;
        line-height: 1.3;
      }

      p {
        font-size: 15px;
        color: #52525b;
        line-height: 1.6;
        margin-bottom: 16px;
      }

      .member-card {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
      }

      .member-avatar {
        width: 44px;
        height: 44px;
        background-color: #6366f1;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 18px;
        font-weight: 700;
        flex-shrink: 0;
      }

      .member-name {
        font-size: 16px;
        font-weight: 600;
        color: #18181b;
      }

      .member-meta {
        font-size: 13px;
        color: #71717a;
        margin-top: 2px;
      }

      .blocker-card {
        background-color: #fef2f2;
        border: 1px solid #fecaca;
        border-left: 4px solid #dc2626;
        border-radius: 8px;
        padding: 20px;
        margin: 24px 0;
      }

      .blocker-label {
        font-size: 12px;
        font-weight: 600;
        color: #dc2626;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
      }

      .blocker-text {
        font-size: 15px;
        color: #18181b;
        line-height: 1.6;
        margin: 0;
      }

      .blocker-image {
        margin-top: 16px;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid #fecaca;
      }

      .blocker-image img {
        width: 100%;
        display: block;
      }

      .standup-section {
        background-color: #fafafa;
        border: 1px solid #e4e4e7;
        border-radius: 8px;
        padding: 20px;
        margin: 24px 0;
      }

      .standup-label {
        font-size: 12px;
        font-weight: 600;
        color: #71717a;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
      }

      .standup-text {
        font-size: 14px;
        color: #3f3f46;
        line-height: 1.6;
        margin: 0 0 16px 0;
      }

      .standup-text:last-child {
        margin-bottom: 0;
      }

      .btn {
        display: block;
        background-color: #6366f1;
        color: #ffffff !important;
        text-decoration: none;
        text-align: center;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        margin: 28px 0;
      }

      .divider {
        border: none;
        border-top: 1px solid #e4e4e7;
        margin: 24px 0;
      }

      .footer {
        background-color: #fafafa;
        border-top: 1px solid #e4e4e7;
        padding: 24px 32px;
        text-align: center;
      }

      .footer p {
        font-size: 13px;
        color: #a1a1aa;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div class="container">

      <!-- Header -->
      <div class="header">
        <div class="logo">Dev<span>Log</span></div>
      </div>

      <!-- Body -->
      <div class="body">
        <div class="tag">🚧 Blocker Alert</div>

        <h1>A team member has a blocker</h1>

        <!-- Member Info -->
        <div class="member-card">
          <div class="member-avatar">
            <%= memberName.charAt(0).toUpperCase() %>
          </div>
          <div>
            <div class="member-name"><%= memberName %></div>
            <div class="member-meta"><%= workspaceName %> · <%= date %></div>
          </div>
        </div>

        <p>
          <strong><%= memberName %></strong> reported a blocker in their
          daily standup that may need your attention.
        </p>

        <!-- Blocker Card -->
        <div class="blocker-card">
          <div class="blocker-label">🚧 Blocker</div>
          <p class="blocker-text"><%= blocker %></p>

          <% if (blockerImageUrl) { %>
          <div class="blocker-image">
            <img src="<%= blockerImageUrl %>" alt="Blocker screenshot" />
          </div>
          <% } %>
        </div>

        <!-- Full Standup Context -->
        <div class="standup-section">
          <p class="standup-label">✅ What they did today</p>
          <p class="standup-text"><%= todayWork %></p>

          <p class="standup-label">🔨 What they plan tomorrow</p>
          <p class="standup-text"><%= tomorrowWork %></p>
        </div>

        <p>
          Visit the workspace dashboard to respond or reassign tasks:
        </p>


        <hr class="divider" />

      </div>

      <!-- Footer -->
      <div class="footer">
        <p>
          You received this because you are an admin of
          <strong><%= workspaceName %></strong> on DevLog.<br />
          © 2026 DevLog. All rights reserved.
        </p>
      </div>

    </div>
  </body>
</html>