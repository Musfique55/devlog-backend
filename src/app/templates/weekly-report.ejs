<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          sans-serif;
        background-color: #f4f4f5;
        padding: 40px 20px;
      }

      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }

      .header {
        background-color: #18181b;
        padding: 32px;
        text-align: center;
      }

      .logo {
        font-size: 24px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
      }

      .logo span {
        color: #6366f1;
      }

      .header-sub {
        font-size: 13px;
        color: #a1a1aa;
        margin-top: 8px;
      }

      .body {
        padding: 40px 32px;
      }

      .tag {
        display: inline-block;
        background-color: #ede9fe;
        color: #6366f1;
        font-size: 12px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 999px;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      h1 {
        font-size: 22px;
        font-weight: 700;
        color: #18181b;
        margin-bottom: 8px;
      }

      .week-range {
        font-size: 14px;
        color: #71717a;
        margin-bottom: 32px;
      }

      /* Stats Row */
      .stats-row {
        display: flex;
        gap: 12px;
        margin-bottom: 32px;
      }

      .stat-card {
        flex: 1;
        background-color: #fafafa;
        border: 1px solid #e4e4e7;
        border-radius: 8px;
        padding: 16px;
        text-align: center;
      }

      .stat-value {
        font-size: 28px;
        font-weight: 800;
        color: #18181b;
        line-height: 1;
      }

      .stat-label {
        font-size: 12px;
        color: #71717a;
        margin-top: 6px;
      }

      /* Section */
      .section-title {
        font-size: 13px;
        font-weight: 700;
        color: #18181b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid #e4e4e7;
      }

      /* Member Row */
      .member-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 0;
        border-bottom: 1px solid #f4f4f5;
      }

      .member-row:last-child {
        border-bottom: none;
      }

      .member-left {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .member-avatar {
        width: 36px;
        height: 36px;
        background-color: #6366f1;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 14px;
        font-weight: 700;
        flex-shrink: 0;
      }

      .member-name {
        font-size: 14px;
        font-weight: 600;
        color: #18181b;
      }

      .member-streak {
        font-size: 12px;
        color: #71717a;
        margin-top: 2px;
      }

      .member-right {
        text-align: right;
      }

      .log-count {
        font-size: 14px;
        font-weight: 700;
        color: #18181b;
      }

      .log-count.full {
        color: #16a34a;
      }

      .log-count.partial {
        color: #d97706;
      }

      .log-count.low {
        color: #dc2626;
      }

      .log-days {
        font-size: 12px;
        color: #71717a;
        margin-top: 2px;
      }

      /* Blocker Section */
      .blocker-item {
        background-color: #fef2f2;
        border: 1px solid #fecaca;
        border-left: 4px solid #dc2626;
        border-radius: 8px;
        padding: 14px 16px;
        margin-bottom: 10px;
      }

      .blocker-meta {
        font-size: 12px;
        color: #dc2626;
        font-weight: 600;
        margin-bottom: 4px;
      }

      .blocker-text {
        font-size: 14px;
        color: #18181b;
      }

      .no-blockers {
        font-size: 14px;
        color: #16a34a;
        padding: 12px 0;
      }

      .section {
        margin-bottom: 32px;
      }

      .btn {
        display: block;
        background-color: #6366f1;
        color: #ffffff !important;
        text-decoration: none;
        text-align: center;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        margin: 28px 0 0 0;
      }

      .footer {
        background-color: #fafafa;
        border-top: 1px solid #e4e4e7;
        padding: 24px 32px;
        text-align: center;
      }

      .footer p {
        font-size: 13px;
        color: #a1a1aa;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div class="container">

      <!-- Header -->
      <div class="header">
        <div class="logo">Dev<span>Log</span></div>
        <div class="header-sub">Weekly Standup Report</div>
      </div>

      <!-- Body -->
      <div class="body">
        <div class="tag">📊 Weekly Report</div>
        <h1><%= workspaceName %></h1>
        <div class="week-range"><%= weekRange %></div>

        <!-- Stats Row -->
        <div class="stats-row">
          <div class="stat-card">
            <div class="stat-value"><%= totalLogs %></div>
            <div class="stat-label">Total Standups</div>
          </div>
          <div class="stat-card">
            <div class="stat-value"><%= totalMembers %></div>
            <div class="stat-label">Team Members</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" style="color: #dc2626;"><%= totalBlockers %></div>
            <div class="stat-label">Blockers</div>
          </div>
        </div>

        <!-- Team Activity -->
        <div class="section">
          <div class="section-title">👥 Team Activity</div>
          <% members.forEach(member => { %>
            <div class="member-row">
              <div class="member-left">
                <div class="member-avatar">
                  <%= member.name.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div class="member-name"><%= member.name %></div>
                  <div class="member-streak">🔥 <%= member.currentStreak %> day streak</div>
                </div>
              </div>
              <div class="member-right">
                <div class="log-count <%= member.logCount === 7 ? 'full' : member.logCount >= 4 ? 'partial' : 'low' %>">
                  <%= member.logCount %>/7 days
                </div>
                <div class="log-days">
                  <% if(member.logCount === 7) { %>
                    ✅ Perfect week!
                  <% } else if(member.logCount >= 4) { %>
                    ⚠️ Missed <%= 7 - member.logCount %> days
                  <% } else { %>
                    ❌ Low activity
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Blockers This Week -->
        <div class="section">
          <div class="section-title">🚧 Blockers This Week</div>
          <% if(blockers.length === 0) { %>
            <div class="no-blockers">✅ No blockers this week!</div>
          <% } else { %>
            <% blockers.forEach(blocker => { %>
              <div class="blocker-item">
                <div class="blocker-meta">
                  <%= blocker.memberName %> · <%= blocker.date %>
                </div>
                <div class="blocker-text"><%= blocker.text %></div>
              </div>
            <% }) %>
          <% } %>
        </div>

        <a href="<%= workspaceUrl %>" class="btn">
          View Full Report →
        </a>

      </div>

      <!-- Footer -->
      <div class="footer">
        <p>
          Weekly report for <strong><%= workspaceName %></strong><br />
          © 2026 DevLog. All rights reserved.
        </p>
      </div>

    </div>
  </body>
</html>